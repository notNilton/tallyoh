// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id           String  @id @default(uuid())
    email        String  @unique
    passwordHash String  @map("password_hash")
    name         String?
    phone        String?
    cpf          String? @unique
    cnpj         String? @unique
    avatarUrl    String? @map("avatar_url")

    subscriptionTier    String    @default("FREE") @map("subscription_tier")
    stripeCustomerId    String?   @unique @map("stripe_customer_id")
    revenueCatId        String?   @unique @map("revenue_cat_id")
    subscriptionExpires DateTime? @map("subscription_expires")
    privacyModeEnabled  Boolean   @default(false) @map("privacy_mode_enabled")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    sharedAccounts AccountAccess[]
    categories     Category[]
    transactions   Transaction[]
    accounts       Account[]
    vehicles       Vehicle[]
    cards          Card[]
    importFiles    ImportFile[]
    importFingerprints ImportFingerprint[]

    @@map("users")
}

enum AccountType {
    CHECKING
    SAVINGS
    CASH
    WALLET
    INVESTMENT
}

enum AccountOwnership {
    PERSONAL
    BUSINESS
}

model Account {
    id     String @id @default(uuid())
    userId String @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    name         String      @db.VarChar(100)
    type         AccountType
    color        String?     @db.VarChar(7)
    icon         String?
    currencyCode String      @default("BRL") @map("currency_code") @db.VarChar(3)

    bankName  String?          @map("bank_name") @db.VarChar(100)
    ownership AccountOwnership @default(PERSONAL)
    cpf       String?          @db.VarChar(14)
    cnpj      String?          @db.VarChar(18)

    isShared   Boolean         @default(false) @map("is_shared")
    sharedWith AccountAccess[]

    balance     Decimal  @default(0.00) @db.Decimal(12, 2)
    creditLimit Decimal? @map("credit_limit") @db.Decimal(12, 2)

    hasDebit  Boolean @default(true)  @map("has_debit")
    hasPix    Boolean @default(true)  @map("has_pix")
    hasCredit Boolean @default(false) @map("has_credit")

    closingDay Int? @map("closing_day")
    dueDay     Int? @map("due_day")

    includeInTotal Boolean @default(true) @map("include_in_total")

    isActive  Boolean   @default(true) @map("is_active")
    deletedAt DateTime? @map("deleted_at")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    transactions   Transaction[]
    balanceHistory BalanceHistory[]

    cards Card[]
    importFiles ImportFile[]

    @@map("accounts")
}

enum CardType {
    CREDIT
    DEBIT
}

model Card {
    id        String   @id @default(uuid())
    userId    String   @map("user_id")
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    accountId String   @map("account_id")
    account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

    name      String   @db.VarChar(100)
    brand     String?  @db.VarChar(50)
    last4     String?  @db.VarChar(4)

    type      CardType
    creditLimit Decimal? @map("credit_limit") @db.Decimal(12, 2)

    // Opcional: permite que cada cartão tenha seu próprio fechamento/vencimento.
    closingDay Int? @map("closing_day")
    dueDay     Int? @map("due_day")

    color     String?  @db.VarChar(7)
    icon      String?

    isActive  Boolean   @default(true) @map("is_active")
    deletedAt DateTime? @map("deleted_at")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    transactions Transaction[]
    importFiles ImportFile[]

    @@map("cards")
}

model AccountAccess {
    id        String  @id @default(uuid())
    accountId String  @map("account_id")
    account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

    userId String @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    role AccessRole @default(VIEWER)

    createdAt DateTime @default(now()) @map("created_at")

    @@unique([accountId, userId])
    @@map("account_access")
}

enum AccessRole {
    EDITOR
    VIEWER
}

model BalanceHistory {
    id        String  @id @default(uuid())
    accountId String  @map("account_id")
    account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

    date    DateTime @db.Date
    balance Decimal  @db.Decimal(12, 2)

    createdAt DateTime @default(now()) @map("created_at")

    @@unique([accountId, date])
    @@map("balance_histories")
}

enum TransactionType {
    INCOME
    EXPENSE
    TRANSFER
    ADJUSTMENT
}

enum TransactionClassification {
    COMMON
    FUEL
    MAINTENANCE
    TRANSFER
}

enum PaymentMethod {
    DEBIT
    CREDIT
}

enum TransactionStatus {
    PENDING
    COMPLETED
    CANCELED
}

enum TransactionChannel {
    CARD_CREDIT
    CARD_DEBIT
    PIX
    BANK
}

model Category {
    id     String @id @default(uuid())
    userId String @map("user_id")
    user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

    name  String          @db.VarChar(50)
    description String?   @db.VarChar(255)
    color String?         @db.VarChar(7)
    type  TransactionType

    parentId String?    @map("parent_id")
    parent   Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: SetNull)
    children Category[] @relation("SubCategories")

    transactions Transaction[]

    @@unique([userId, name, type])
    @@map("categories")
}

model Tag {
    id    String @id @default(uuid())
    name  String
    color String? @db.VarChar(7)

    transactionTags TransactionTag[]

    @@map("tags")
}

model TransactionTag {
    transactionId String      @map("transaction_id")
    transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
    tagId         String      @map("tag_id")
    tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

    @@id([transactionId, tagId])
    @@map("_transaction_tags")
}

model Transaction {
    id     String @id @default(uuid())
    userId String @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    accountId String  @map("account_id")
    account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

    cardId String? @map("card_id")
    card   Card?   @relation(fields: [cardId], references: [id], onDelete: SetNull)

    categoryId String?   @map("category_id")
    category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

    tags TransactionTag[]

    type        TransactionType
    amount      Decimal         @db.Decimal(12, 2)
    date        DateTime
    description String          @db.VarChar(255)
    notes       String?         @db.Text

    status TransactionStatus @default(COMPLETED)

    attachmentUrl  String?                   @map("attachment_url")
    currencyCode   String                    @default("BRL") @map("currency_code") @db.VarChar(3)
    classification TransactionClassification @default(COMMON)
    paymentMethod  PaymentMethod             @default(DEBIT) @map("payment_method")
    isRecurring    Boolean                   @default(false) @map("is_recurring")
    channel        TransactionChannel        @default(BANK) @map("channel")

    // Para cartão de CRÉDITO: não afeta saldo da conta mãe (afeta limite/dívida do cartão).
    // Para conta normal e cartão de DÉBITO: afeta saldo normalmente.
    affectsAccount Boolean @default(true) @map("affects_account")

    installmentId     String?      @map("installment_id")
    installment       Installment? @relation(fields: [installmentId], references: [id], onDelete: Cascade)
    installmentNum    Int?         @map("installment_num")
    totalInstallments Int?         @map("total_installments")

    transferOut Transfer? @relation("TransferSource")
    transferIn  Transfer? @relation("TransferDestination")

    // Opcional: guarda o id da transação original (ex.: estorno/ajuste).
    originalTransactionId String? @map("original_transaction_id")

    isActive  Boolean   @default(true) @map("is_active")
    deletedAt DateTime? @map("deleted_at")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    refuelingLog   RefuelingLog?
    maintenanceLog VehicleMaintenance?

    @@index([date])
    @@index([userId, date])
    @@index([userId, cardId, date])
    @@map("transactions")
}

model Transfer {
    id String @id @default(uuid())

    sourceTransactionId String      @unique @map("source_transaction_id")
    sourceTransaction   Transaction @relation("TransferSource", fields: [sourceTransactionId], references: [id], onDelete: Cascade)

    destinationTransactionId String      @unique @map("destination_transaction_id")
    destinationTransaction   Transaction @relation("TransferDestination", fields: [destinationTransactionId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now()) @map("created_at")

    @@map("transfers")
}

model Installment {
    id     String @id @default(uuid())
    userId String @map("user_id")

    totalAmount Decimal @map("total_amount") @db.Decimal(12, 2)
    totalParts  Int     @map("total_parts")

    description String   @db.VarChar(255)
    date        DateTime

    transactions Transaction[]

    createdAt DateTime @default(now()) @map("created_at")

    @@map("installments")
}

model ImportFile {
    id     String @id @default(uuid())
    userId String @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    accountId String? @map("account_id")
    account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

    cardId String? @map("card_id")
    card   Card?   @relation(fields: [cardId], references: [id], onDelete: SetNull)

    sha256       String @db.VarChar(64)
    filename     String? @map("filename") @db.VarChar(255)
    sizeBytes    Int?    @map("size_bytes")
    importedAt   DateTime @default(now()) @map("imported_at")

    fingerprints ImportFingerprint[]

    @@unique([userId, sha256, accountId, cardId])
    @@index([userId, importedAt])
    @@map("import_files")
}

model ImportFingerprint {
    id     String @id @default(uuid())
    userId String @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    importFileId String @map("import_file_id")
    importFile   ImportFile @relation(fields: [importFileId], references: [id], onDelete: Cascade)

    // hash de uma linha normalizada (transação)
    sha256 String @db.VarChar(64)

    createdAt DateTime @default(now()) @map("created_at")

    @@unique([userId, sha256])
    @@index([importFileId])
    @@map("import_fingerprints")
}

model AuditLog {
    id     String  @id @default(uuid())
    userId String? @map("user_id")

    action   String @db.VarChar(100)
    entity   String @db.VarChar(50)
    entityId String @map("entity_id")

    oldValues Json? @map("old_values")
    newValues Json? @map("new_values")

    ipAddress String? @map("ip_address") @db.VarChar(45)
    userAgent String? @map("user_agent") @db.Text

    createdAt DateTime @default(now()) @map("created_at")

    @@index([entity, entityId])
    @@index([userId])
    @@map("audit_logs")
}

model Vehicle {
    id     String @id @default(uuid())
    userId String @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    name         String  @db.VarChar(100)
    licensePlate String? @map("license_plate") @db.VarChar(10)
    brand        String? @db.VarChar(50)
    model        String? @db.VarChar(50)
    year         Int?
    tank         Decimal @default(50.00) @map("tank") @db.Decimal(10, 2)

    isActive  Boolean   @default(true) @map("is_active")
    deletedAt DateTime? @map("deleted_at")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    refuelings   RefuelingLog[]
    maintenances VehicleMaintenance[]

    @@map("vehicles")
}

model RefuelingLog {
    id        String  @id @default(uuid())
    vehicleId String  @map("vehicle_id")
    vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    transactionId String      @unique @map("transaction_id")
    transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

    fuelType      FuelType?
    station       String?   @db.VarChar(100)
    odometer      Decimal   @db.Decimal(10, 2)
    fuelLiters    Decimal   @map("fuel_liters") @db.Decimal(8, 3)
    pricePerLiter Decimal   @map("price_per_liter") @db.Decimal(8, 3)
    isFullTank    Boolean   @default(true) @map("is_full_tank")

    createdAt DateTime @default(now()) @map("created_at")

    @@map("refueling_logs")
}

model VehicleMaintenance {
    id        String  @id @default(uuid())
    vehicleId String  @map("vehicle_id")
    vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    transactionId String      @unique @map("transaction_id")
    transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

    type        MaintenanceType
    description String?         @db.VarChar(255)
    odometer    Decimal?        @db.Decimal(10, 2)
    provider    String?         @db.VarChar(100)

    createdAt DateTime @default(now()) @map("created_at")

    @@map("vehicle_maintenances")
}

enum MaintenanceType {
    OIL_CHANGE
    TIRE_CHANGE
    PREVENTIVE
    REPAIR
    PART_REPLACEMENT
    OTHER
}

enum FuelType {
    GASOLINA_COMUM
    GASOLINA_ADITIVADA
    ETANOL
    DIESEL
    GNV
}
