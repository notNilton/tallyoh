// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id           String  @id @default(uuid())
    email        String  @unique
    passwordHash String  @map("password_hash")
    name         String?
    phone        String?
    cpf          String? @unique
    cnpj         String? @unique
    avatarUrl    String? @map("avatar_url")

    subscriptionTier    String    @default("FREE") @map("subscription_tier")
    stripeCustomerId    String?   @unique @map("stripe_customer_id")
    revenueCatId        String?   @unique @map("revenue_cat_id")
    subscriptionExpires DateTime? @map("subscription_expires")
    privacyModeEnabled  Boolean   @default(false) @map("privacy_mode_enabled")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    sharedAccounts AccountAccess[]
    categories     Category[]
    transactions   Transaction[]
    budgets        Budget[]
    goals          Goal[]
    accounts       Account[]
    vehicles       Vehicle[]

    @@map("users")
}

enum AccountType {
    CHECKING
    SAVINGS
    CREDIT_CARD
    CASH
    WALLET
    INVESTMENT
}

model Account {
    id     String @id @default(uuid())
    userId String @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    name         String      @db.VarChar(100)
    type         AccountType
    color        String?     @db.VarChar(7)
    icon         String?
    currencyCode String      @default("BRL") @map("currency_code") @db.VarChar(3)

    isShared   Boolean         @default(false) @map("is_shared")
    sharedWith AccountAccess[]

    balance Decimal @default(0.00) @db.Decimal(12, 2)

    creditLimit Decimal? @map("credit_limit") @db.Decimal(12, 2)
    closingDay  Int?     @map("closing_day")
    dueDay      Int?     @map("due_day")

    includeInTotal Boolean @default(true) @map("include_in_total")

    isActive  Boolean   @default(true) @map("is_active")
    deletedAt DateTime? @map("deleted_at")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    transactions   Transaction[]
    balanceHistory BalanceHistory[]
    statements     CreditCardStatement[]

    @@map("accounts")
}

model AccountAccess {
    id        String  @id @default(uuid())
    accountId String  @map("account_id")
    account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

    userId String @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    role AccessRole @default(VIEWER)

    createdAt DateTime @default(now()) @map("created_at")

    @@unique([accountId, userId])
    @@map("account_access")
}

enum AccessRole {
    EDITOR
    VIEWER
}

model CreditCardStatement {
    id        String  @id @default(uuid())
    accountId String  @map("account_id")
    account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

    month Int
    year  Int

    status      StatementStatus @default(OPEN)
    totalAmount Decimal         @default(0.00) @map("total_amount") @db.Decimal(12, 2)
    paidAmount  Decimal         @default(0.00) @map("paid_amount") @db.Decimal(12, 2)

    dueDate     DateTime @map("due_date") @db.Date
    closingDate DateTime @map("closing_date") @db.Date

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    transactions Transaction[]

    @@unique([accountId, month, year])
    @@map("credit_card_statements")
}

enum StatementStatus {
    OPEN
    CLOSED
    PAID
}

model BalanceHistory {
    id        String  @id @default(uuid())
    accountId String  @map("account_id")
    account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

    date    DateTime @db.Date
    balance Decimal  @db.Decimal(12, 2)

    createdAt DateTime @default(now()) @map("created_at")

    @@unique([accountId, date])
    @@map("balance_histories")
}

enum TransactionType {
    INCOME
    EXPENSE
    TRANSFER
}

enum TransactionClassification {
    COMMON
    FUEL
}

enum TransactionStatus {
    PENDING
    COMPLETED
    CANCELED
}

model Category {
    id     String @id @default(uuid())
    userId String @map("user_id")
    user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

    name  String          @db.VarChar(50)
    icon  String?
    color String?         @db.VarChar(7)
    type  TransactionType

    parentId String?    @map("parent_id")
    parent   Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: SetNull)
    children Category[] @relation("SubCategories")

    transactions Transaction[]
    budgets      Budget[]

    @@unique([userId, name, type])
    @@map("categories")
}

model Tag {
    id   String @id @default(uuid())
    name String

    transactionTags TransactionTag[]

    @@map("tags")
}

model TransactionTag {
    transactionId String      @map("transaction_id")
    transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
    tagId         String      @map("tag_id")
    tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

    @@id([transactionId, tagId])
    @@map("_transaction_tags")
}

model Transaction {
    id     String @id @default(uuid())
    userId String @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    accountId String  @map("account_id")
    account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

    categoryId String?   @map("category_id")
    category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

    tags TransactionTag[]

    type        TransactionType
    amount      Decimal         @db.Decimal(12, 2)
    date        DateTime
    description String          @db.VarChar(255)
    notes       String?         @db.Text

    status TransactionStatus @default(COMPLETED)

    attachmentUrl  String?                   @map("attachment_url")
    currencyCode   String                    @default("BRL") @map("currency_code") @db.VarChar(3)
    classification TransactionClassification @default(COMMON)
    isRecurring    Boolean                   @default(false) @map("is_recurring")

    statementId String?              @map("statement_id")
    statement   CreditCardStatement? @relation(fields: [statementId], references: [id], onDelete: SetNull)

    goalId String? @map("goal_id")
    goal   Goal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)

    installmentId     String?      @map("installment_id")
    installment       Installment? @relation(fields: [installmentId], references: [id], onDelete: Cascade)
    installmentNum    Int?         @map("installment_num")
    totalInstallments Int?         @map("total_installments")

    transferOut Transfer? @relation("TransferSource")
    transferIn  Transfer? @relation("TransferDestination")

    isActive  Boolean   @default(true) @map("is_active")
    deletedAt DateTime? @map("deleted_at")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    refuelingLog RefuelingLog?

    @@index([date])
    @@index([userId, date])
    @@map("transactions")
}

model Transfer {
    id String @id @default(uuid())

    sourceTransactionId String      @unique @map("source_transaction_id")
    sourceTransaction   Transaction @relation("TransferSource", fields: [sourceTransactionId], references: [id], onDelete: Cascade)

    destinationTransactionId String      @unique @map("destination_transaction_id")
    destinationTransaction   Transaction @relation("TransferDestination", fields: [destinationTransactionId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now()) @map("created_at")

    @@map("transfers")
}

model Installment {
    id     String @id @default(uuid())
    userId String @map("user_id")

    totalAmount Decimal @map("total_amount") @db.Decimal(12, 2)
    totalParts  Int     @map("total_parts")

    description String   @db.VarChar(255)
    date        DateTime

    transactions Transaction[]

    createdAt DateTime @default(now()) @map("created_at")

    @@map("installments")
}

model Budget {
    id     String @id @default(uuid())
    userId String @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    categoryId String?   @map("category_id")
    category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

    amountLimit Decimal @map("amount_limit") @db.Decimal(12, 2)
    month       Int
    year        Int

    rolloverAmount Decimal @default(0.00) @map("rollover_amount") @db.Decimal(12, 2)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@unique([userId, categoryId, month, year])
    @@map("budgets")
}

model Goal {
    id     String @id @default(uuid())
    userId String @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    name          String  @db.VarChar(100)
    targetAmount  Decimal @map("target_amount") @db.Decimal(12, 2)
    currentAmount Decimal @default(0.00) @map("current_amount") @db.Decimal(12, 2)

    deadline DateTime?
    color    String?   @db.VarChar(7)
    icon     String?

    transactions Transaction[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("goals")
}

model AuditLog {
    id     String  @id @default(uuid())
    userId String? @map("user_id")

    action   String @db.VarChar(100)
    entity   String @db.VarChar(50)
    entityId String @map("entity_id")

    oldValues Json? @map("old_values")
    newValues Json? @map("new_values")

    ipAddress String? @map("ip_address") @db.VarChar(45)
    userAgent String? @map("user_agent") @db.Text

    createdAt DateTime @default(now()) @map("created_at")

    @@index([entity, entityId])
    @@index([userId])
    @@map("audit_logs")
}

model Vehicle {
    id     String @id @default(uuid())
    userId String @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    name         String  @db.VarChar(100)
    licensePlate String? @map("license_plate") @db.VarChar(10)
    make         String? @db.VarChar(50)
    model        String? @db.VarChar(50)
    year         Int?
    tank         Decimal @default(50.00) @map("tank") @db.Decimal(10, 2)

    isActive  Boolean   @default(true) @map("is_active")
    deletedAt DateTime? @map("deleted_at")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    refuelings RefuelingLog[]

    @@map("vehicles")
}

model RefuelingLog {
    id        String  @id @default(uuid())
    vehicleId String  @map("vehicle_id")
    vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    transactionId String      @unique @map("transaction_id")
    transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

    fuelType      FuelType?
    station       String?   @db.VarChar(100)
    odometer      Decimal   @db.Decimal(10, 2)
    fuelLiters    Decimal   @map("fuel_liters") @db.Decimal(8, 3)
    pricePerLiter Decimal   @map("price_per_liter") @db.Decimal(8, 3)
    isFullTank    Boolean   @default(true) @map("is_full_tank")

    createdAt DateTime @default(now()) @map("created_at")

    @@map("refueling_logs")
}

enum FuelType {
    GASOLINA_COMUM
    GASOLINA_ADITIVADA
    ETANOL
    DIESEL
    GNV
}
