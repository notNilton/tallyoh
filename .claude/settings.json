{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx ts-node *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status)",
      "Bash(git stash *)",
      "Bash(git pull *)",
      "Bash(git merge *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/on-schema-change.sh"
          }
        ]
      }
    ]
  }
}
